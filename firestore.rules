rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile. Admins (checked by role in their user doc) can read any user profile.
    // Users can write (update) their own profile.
    match /users/{userId} {
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
      // Create is typically handled during registration, where rules might be different or done via trusted server code.
      // For simplicity, let's assume createUserDetails in userService handles new user doc creation securely.
      // allow create: if request.auth != null; // Or more specific logic if needed
    }

    match /complaints/{complaintId} {
      // Any authenticated user can create a complaint.
      allow create: if request.auth != null;

      // Users can read complaints if:
      // 1. They are the customer who submitted it.
      // 2. They are the engineer assigned to it.
      // 3. They are an admin (checked by role in their user doc).
      allow read: if request.auth != null &&
                   (request.auth.uid == resource.data.customerId ||
                    request.auth.uid == resource.data.assignedTo ||
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Users can update complaints if:
      // 1. They are the engineer assigned to it.
      // 2. They are an admin.
      // (Customers typically don't update complaints directly after submission, maybe only add notes if that feature exists)
      allow update: if request.auth != null &&
                     (request.auth.uid == resource.data.assignedTo ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Only admins can delete complaints.
      allow delete: if request.auth != null &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
